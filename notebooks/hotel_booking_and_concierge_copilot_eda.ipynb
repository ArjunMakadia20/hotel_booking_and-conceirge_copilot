from pathlib import Path
import sys

import numpy as np
import pandas as pd
import shap
from sklearn.ensemble import RandomForestRegressor
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score
from sklearn.model_selection import train_test_split

sys.path.append(str(Path.cwd() / "src"))

from data_processing import (
    clean_hotel_booking_data,
    engineer_features,
    prepare_features,
    split_data,
    summarize_dataframe,
)
from modeling import train_random_forest, train_linear_regression, evaluate_regression

DATA_PATH = Path("data/hotel_bookings.csv")
assert DATA_PATH.exists(), f"Dataset not found at {DATA_PATH}"

hotel_df = pd.read_csv(DATA_PATH)
print("Loaded", DATA_PATH, "shape", hotel_df.shape)
hotel_df.head()
</VSCode.Cell>
<VSCode.Cell language="markdown">
### First look at the data
Dataset is loaded from `data/hotel_bookings.csv`, and the first rows are displayed.
</VSCode.Cell>
<VSCode.Cell language="python">
summary = summarize_dataframe(hotel_df)
print("Shape:", summary["shape"])
print("\nMissing values:")
print(pd.Series(summary["missing_values"]).sort_values(ascending=False).head(15))
print("\nDuplicate rows:", summary["duplicates"])
</VSCode.Cell>
<VSCode.Cell language="markdown">
### Data summary
This section reports dataset shape, missing values, and duplicate counts.
</VSCode.Cell>
<VSCode.Cell language="python">
hotel_clean = clean_hotel_booking_data(hotel_df)
print("After cleaning:", hotel_clean.shape)
print("Missing values after cleaning:")
print(hotel_clean.isna().sum().sort_values(ascending=False).head(15))
hotel_clean.head()
</VSCode.Cell>
<VSCode.Cell language="markdown">
### Cleaning
Cleaning removes duplicates, imputes sparse columns, fixes invalid values, and drops rows missing the target `adr`.
</VSCode.Cell>
<VSCode.Cell language="python">
hotel_features = engineer_features(hotel_clean)
print("Engineered features available:", [c for c in hotel_features.columns if c not in hotel_clean.columns])
hotel_features.head()
</VSCode.Cell>
<VSCode.Cell language="markdown">
### Feature engineering
New features include total guests, total nights, arrival month number, and seasonal information.
</VSCode.Cell>
<VSCode.Cell language="python">
X, y = prepare_features(hotel_features, target_column="adr")
print("Feature matrix shape:", X.shape)
print("Target vector shape:", y.shape)
X_train, X_test, y_train, y_test = split_data(X, y, test_size=0.2, random_state=42)
print("Train/test split:", X_train.shape, X_test.shape)
</VSCode.Cell>
<VSCode.Cell language="markdown">
### Train/test split
This prepares the model input and splits the data for evaluation.
</VSCode.Cell>
<VSCode.Cell language="python">
lr_model = train_linear_regression(X_train, y_train)
rf_model = train_random_forest(X_train, y_train, n_estimators=100, max_depth=10)

lr_eval = evaluate_regression(lr_model, X_test, y_test)
rf_eval = evaluate_regression(rf_model, X_test, y_test)

print("Linear Regression:", lr_eval)
print("Random Forest:", rf_eval)
</VSCode.Cell>
<VSCode.Cell language="markdown">
### Model evaluation
Regression metrics are computed for a linear baseline and a random forest model.
</VSCode.Cell>
<VSCode.Cell language="python">
explainer = shap.Explainer(rf_model, X_train)
shap_values = explainer(X_test)

importance_df = pd.DataFrame({
    "feature": X.columns,
    "mean_abs_shap": np.abs(shap_values.values).mean(axis=0),
}).sort_values("mean_abs_shap", ascending=False).reset_index(drop=True)

importance_df.head(15)
</VSCode.Cell>
<VSCode.Cell language="markdown">
### SHAP feature importance
The top features are ranked using mean absolute SHAP values from the random forest model.
</VSCode.Cell>
